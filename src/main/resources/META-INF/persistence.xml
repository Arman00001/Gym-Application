<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit
            name="default"
            transaction-type="RESOURCE_LOCAL">
        <class>com.epam.gymapp.persistence.entity.User</class>
        <class>com.epam.gymapp.persistence.entity.Trainee</class>
        <class>com.epam.gymapp.persistence.entity.Trainer</class>
        <class>com.epam.gymapp.persistence.entity.Training</class>
        <class>com.epam.gymapp.persistence.entity.TrainingType</class>

        <properties>
            <property name="hibernate.jdbc.time_zone" value="UTC+4"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/gymapp"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
        </properties>
    </persistence-unit>


</persistence>
